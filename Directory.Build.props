<Project>

  <!-- Shared strict-quality settings. Rule severities live in .editorconfig. -->
  <PropertyGroup>
    <!-- Single source of version; release-please rewrites this line via the x-release-please-version marker. Do not hand-edit. -->
    <Version>0.1.0</Version> <!-- x-release-please-version -->

    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- Vulnerability audit incl. transitive deps; keep NU19xx as warnings so TreatWarningsAsErrors doesn't break local builds (CI nuget-audit.yml is the gate). -->
    <NuGetAudit>true</NuGetAudit>
    <NuGetAuditMode>all</NuGetAuditMode>
    <WarningsNotAsErrors>$(WarningsNotAsErrors);NU1901;NU1902;NU1903;NU1904</WarningsNotAsErrors>

    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <AnalysisLevel>latest-all</AnalysisLevel>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <CodeAnalysisTreatWarningsAsErrors>true</CodeAnalysisTreatWarningsAsErrors>

    <!-- Exclude generated files (*.g.cs / XAML) from analyzers to avoid false positives. -->
    <GeneratedCodeAnalysisSeverity>None</GeneratedCodeAnalysisSeverity>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="StyleCop.Analyzers" Version="1.2.0-beta.556">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Roslynator.Analyzers" Version="4.15.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

</Project>
