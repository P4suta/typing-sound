# TypingSound — code style / analyzer severities.
# Policy: strict from the start. Valuable rules are errors; only legacy StyleCop rules that
# clash with modern C# are disabled.
root = true

[*]
charset = utf-8
# Match .gitattributes (eol=lf) so dotnet format stays consistent.
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{csproj,props,targets,xml}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.cs]
# --- Language style (IDExxxx). Enforced at build time via EnforceCodeStyleInBuild=true. ---
csharp_style_namespace_declarations = file_scoped:error
csharp_using_directive_placement = outside_namespace:error
dotnet_sort_system_directives_first = true
csharp_prefer_braces = true:error
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_expression_bodied_methods = true:silent
dotnet_style_qualification_for_field = false:error
dotnet_style_qualification_for_property = false:error
dotnet_style_qualification_for_method = false:error
dotnet_style_require_accessibility_modifiers = for_non_interface_members:error
dotnet_style_readonly_field = true:warning
csharp_prefer_simple_using_statement = true:suggestion
csharp_style_prefer_primary_constructors = false:suggestion

# --- Naming: private fields must be _camelCase ---
dotnet_naming_rule.private_fields_underscore.severity = error
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_camel
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel.capitalization = camel_case
dotnet_naming_style.underscore_camel.required_prefix = _

# --- StyleCop: disable rules that clash with modern C# ---
dotnet_diagnostic.SA1101.severity = none   # no this. prefix
dotnet_diagnostic.SA1200.severity = none   # usings may sit outside the namespace
dotnet_diagnostic.SA1309.severity = none   # allow _-prefixed fields (enforced by the naming rule)
dotnet_diagnostic.SA1633.severity = none   # no file header
dotnet_diagnostic.SA1413.severity = none   # no trailing comma in multi-line initializers

# --- StyleCop: documentation rules off; public API docs are covered by CS1591 in Core ---
dotnet_diagnostic.SA1600.severity = none   # element documentation (covered by CS1591)
dotnet_diagnostic.SA1601.severity = none
dotnet_diagnostic.SA1602.severity = none
dotnet_diagnostic.SA1604.severity = none
dotnet_diagnostic.SA1605.severity = none
dotnet_diagnostic.SA1606.severity = none
dotnet_diagnostic.SA1611.severity = none   # don't require param docs
dotnet_diagnostic.SA1615.severity = none   # don't require return docs
dotnet_diagnostic.SA1618.severity = none
dotnet_diagnostic.SA1623.severity = none   # don't require Gets/Sets boilerplate in property docs
dotnet_diagnostic.SA1629.severity = none   # don't require doc sentences to end with a period
dotnet_diagnostic.SA1642.severity = none

# --- CA: relax only rules whose premise doesn't categorically hold project-wide, with a reason ---
dotnet_diagnostic.CA1303.severity = none   # localized-string requirement; this app is not localized, so N/A project-wide.
dotnet_diagnostic.CA2007.severity = none   # ConfigureAwait(false); unsuitable for a WinUI app that must stay on the UI thread.
dotnet_diagnostic.SA0001.severity = none   # XML comment analysis off where doc generation is off (Core enables it separately).

# Not blanket-disabled. Use a targeted [SuppressMessage] with a reason at each site instead:
#   CA1031 (catch general Exception) — only at boundaries where exceptions must not escape (hook / timer Tick / sound load).
#   CA1003 (Action-typed events)     — only for parameterless internal signals.
#   CA1716 (reserved-word clash Select/Stop/Next) — only on standalone APIs with no cross-language interop.
#   CA5394 (non-crypto RNG)          — only for non-security random sound selection.

[*Tests*.cs]
# Tests need no documentation.
dotnet_diagnostic.CS1591.severity = none
