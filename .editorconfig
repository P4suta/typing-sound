# TypingSound — コーディング規約 / アナライザ重大度
# 方針: 「最初から超厳格」。価値ある規則はエラーに寄せ、モダン C# と衝突する古い StyleCop 規則だけ無効化する。
root = true

[*]
charset = utf-8
# リポジトリは .gitattributes(eol=lf)で LF に正規化される。dotnet format と齟齬が出ないよう
# ここも lf に合わせる(以前は crlf で、CI の整形チェックが全 .cs を誤検出していた)。
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{csproj,props,targets,xml}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.cs]
# --- 言語スタイル(IDExxxx)。EnforceCodeStyleInBuild=true でビルド時にも効く。 ---
csharp_style_namespace_declarations = file_scoped:error
csharp_using_directive_placement = outside_namespace:error
dotnet_sort_system_directives_first = true
csharp_prefer_braces = true:error
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_expression_bodied_methods = true:silent
dotnet_style_qualification_for_field = false:error
dotnet_style_qualification_for_property = false:error
dotnet_style_qualification_for_method = false:error
dotnet_style_require_accessibility_modifiers = for_non_interface_members:error
dotnet_style_readonly_field = true:warning
csharp_prefer_simple_using_statement = true:suggestion
csharp_style_prefer_primary_constructors = false:suggestion

# --- 命名規則: private フィールドは _camelCase を必須にする ---
dotnet_naming_rule.private_fields_underscore.severity = error
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_camel
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel.capitalization = camel_case
dotnet_naming_style.underscore_camel.required_prefix = _

# --- StyleCop: モダン C# と衝突する規則を無効化 ---
dotnet_diagnostic.SA1101.severity = none   # this. プレフィックス不要
dotnet_diagnostic.SA1200.severity = none   # using は namespace の外でよい
dotnet_diagnostic.SA1309.severity = none   # _ 始まりフィールドを許可(命名規則側で別途強制)
dotnet_diagnostic.SA1633.severity = none   # ファイルヘッダ不要
dotnet_diagnostic.SA1413.severity = none   # 複数行初期化子の末尾カンマ強制はしない

# --- StyleCop: ドキュメント系は無効化。公開 API ドキュメントは Core の CS1591 で担保する ---
dotnet_diagnostic.SA1600.severity = none   # 要素ドキュメント必須(→ CS1591 で代替)
dotnet_diagnostic.SA1601.severity = none
dotnet_diagnostic.SA1602.severity = none
dotnet_diagnostic.SA1604.severity = none
dotnet_diagnostic.SA1605.severity = none
dotnet_diagnostic.SA1606.severity = none
dotnet_diagnostic.SA1611.severity = none   # パラメータ doc 必須にしない
dotnet_diagnostic.SA1615.severity = none   # 戻り値 doc 必須にしない
dotnet_diagnostic.SA1618.severity = none
dotnet_diagnostic.SA1623.severity = none   # プロパティ doc の定型文(Gets/Sets)強制を外す
dotnet_diagnostic.SA1629.severity = none   # doc 末尾ピリオド強制を外す(日本語ドキュメント対応)
dotnet_diagnostic.SA1642.severity = none

# --- CA: 前提がプロジェクト全体で categorically 当てはまらない規則のみ、理由付きでポリシー緩和する ---
dotnet_diagnostic.CA1303.severity = none   # リテラル文字列のローカライズ要求。本アプリは非ローカライズ(日本語固定)のため全体で不要。
dotnet_diagnostic.CA2007.severity = none   # ConfigureAwait(false) 要求。UI スレッド継続が必須の WinUI アプリには全体で不適。
dotnet_diagnostic.SA0001.severity = none   # doc 生成 OFF のプロジェクトでの XML コメント解析無効通知(Core は doc 生成 ON で別途有効)。

# 以下は blanket 無効化しない。該当箇所にのみ理由付き [SuppressMessage] を置き、どこで・なぜ許容したかをコードに残す:
#   CA1031(一般 Exception catch) … 例外を越えさせてはならない境界(フック/タイマー Tick/音読込)でのみ。
#   CA1003(Action イベント)       … パラメータなしの内部シグナルでのみ。
#   CA1716(予約語衝突 Select/Stop/Next) … スタンドアロンで他言語相互運用しない該当 API でのみ。
#   CA5394(非暗号乱数)            … 音選択という非セキュリティ用途の乱数生成でのみ。

[*Tests*.cs]
# テストのドキュメント要求はさらに不要(Core 以外は doc 生成 OFF のため実質効かないが明示)
dotnet_diagnostic.CS1591.severity = none
