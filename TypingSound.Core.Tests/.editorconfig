# Test project-specific analyzer tweaks (core rules stay strict).
[*.cs]
dotnet_diagnostic.CA1707.severity = none   # allow underscores in test names (Method_Scenario_Expected)
dotnet_diagnostic.CA1515.severity = none   # test classes are public for xUnit discovery
dotnet_diagnostic.CS1591.severity = none   # tests need no documentation
dotnet_diagnostic.CA2000.severity = none   # don't force disposal of short-lived IDisposable in tests
dotnet_diagnostic.CA1861.severity = none   # allow constant array literals in assertions
dotnet_diagnostic.SA0001.severity = none   # doc generation off, so XML comment analysis can stay off
